    {
      "name": "1. Health Check",
      "item": [
        {
          "name": "GET /api/ping - Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('success is true', function () {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.message).to.eql('pong');",
                  "  pm.expect(json).to.have.property('uptime');",
                  "  pm.expect(json).to.have.property('timestamp');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/ping",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ping"]
            }
          },
          "response": [
            {
              "name": "200 OK - Expected Response",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"message\": \"pong\",\n  \"uptime\": 42.357,\n  \"timestamp\": \"2026-03-13T10:00:00.000Z\"\n}"
            }
          ]
        }
      ]
    },
